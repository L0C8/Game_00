  <events>
    <event eventtype="0" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>/// init camera freeview
// camera variables
z = 5; 
d = 0;
dz = 0;
vsp = 0;
hsp = 0; 
move_sp = 0;
move_st = 0;
move_ac = 0.5;
move_ac_max = 10;
// draw variables
display = true;
// camera mouse controls
xto = x+1; 
yto = y;
zto = z;
zdir = 0;
// camera keyboard controls
fr = ord("W");
bk = ord("S");
lf = ord("A");
rt = ord("D");
up = ord("E");
dn = ord("Q");
// d3d 
d3d_start();    
display_reset(0,true);  
draw_set_color(c_white); 


</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>/// process keyboard input
// check input
move_sp += keyboard_check(fr)*move_ac; 
move_sp -= keyboard_check(bk)*move_ac;
move_st += keyboard_check(lf)*move_ac;
move_st -= keyboard_check(rt)*move_ac; 
// slow camera
if (!keyboard_check(fr) &amp;&amp; !keyboard_check(bk) &amp;&amp; move_sp != 0)
    move_sp -= move_ac*sign(move_sp);
if (!keyboard_check(lf) &amp;&amp; !keyboard_check(rt) &amp;&amp; move_st != 0)
    move_st -= move_ac*sign(move_st);
// set elevation
z += keyboard_check(up)-keyboard_check(dn)*move_ac*2;
// max speed 
move_sp = clamp(move_sp,-move_ac_max,move_ac_max);
move_st = clamp(move_st,-move_ac_max,move_ac_max);
// apply movement
hsp = lengthdir_x(move_sp, direction) + lengthdir_x(move_st,direction+90);
vsp = lengthdir_y(move_sp, direction) + lengthdir_y(move_st,direction+90); 
x += hsp; 
y += vsp;

</string>
          </argument>
        </arguments>
      </action>
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>/// process mouse input
direction -= (display_mouse_get_x() - display_get_width()/2) / 8;   // set mouse direction
zdir -= (display_mouse_get_y() - display_get_height()/2)/10;        // direction of object 

// clamp 
zdir = clamp(zdir, -70,70) // sets zdir's max and min

// set directions
d = degtorad(direction);
zd = degtorad(zdir);
xto = x + cos(d) * abs(sin(zd) + sign(-zdir));
yto = y - sin(d) * abs(sin(zd) + sign(-zdir)); 
zto = z + sin(zd); 

if(obj_game._3d){
    // reset mouse 
    var centerx = display_get_width()/2;
    var centery = display_get_height()/2; 
    display_mouse_set(centerx,centery);
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
