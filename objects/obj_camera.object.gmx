        <arguments>
          <argument>
            <kind>1</kind>
            <string>/// Draw 2d
if(display){
    // draw field of view
    draw_set_color(c_green);
    var draw_len=90;
    var endx1 = lengthdir_x(draw_len, direction+55);
    var endy1 = lengthdir_y(draw_len, direction+55);
    var endx2 = lengthdir_x(draw_len, direction-55);
    var endy2 = lengthdir_y(draw_len, direction-55);
    draw_line(x,y, x+endx1, y+endy1);
    draw_line(x,y, x+endx2, y+endy2);
    draw_set_color(c_red);
    draw_set_alpha(0.25);
    draw_triangle(x,y,x+endx1,y+endy1,x+endx2,y+endy2,1);
    draw_set_color(c_white);
}
draw_self();

</string>
          </argument>
        </arguments>
